# Only track project files
*

# Planning directory
!.planning/
!.planning/**

# Oracle Cards web app
!apps/
!apps/oracle/
!apps/oracle/**

# Orb backend service
!services/
!services/orb-backend/
!services/orb-backend/**

# Launchd plist
!Library/
!Library/LaunchAgents/
!Library/LaunchAgents/com.claw.orb-backend.plist

!package.json

# QR code generation scripts
!scripts/
!scripts/**

# POV Globe firmware
!firmware/
!firmware/**

# Generated assets (QR codes, print files)
!assets/
!assets/**

# Exclude large generated card PNGs (regenerate with scripts/generate-card-designs.ts)
assets/card-designs/*.png

# Exclude print-assets staging images
apps/oracle/public/print-assets/

!.gitignore

# Exclude venvs and caches from tracked dirs
**/.venv/
**/__pycache__/
**/*.pyc
**/node_modules/
**/.env
