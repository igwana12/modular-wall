# Wall Controller environment variables
# Copy to .env and customize

WALL_PORT=8200
WALL_HOST=0.0.0.0
WALL_DEBUG=false

# Module discovery
WALL_MDNS_ENABLED=true
WALL_MQTT_ENABLED=false
WALL_MQTT_BROKER=localhost:1883
WALL_DISCOVERY_INTERVAL=30

# Module defaults
WALL_HEARTBEAT_TIMEOUT=60
WALL_MAX_MODULES=50
WALL_DEFAULT_BRIGHTNESS=80
